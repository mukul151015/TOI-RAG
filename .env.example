APP_NAME=TOI RAG API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

SUPABASE_DB_DSN=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_VERIFY_SSL=true
OPENAI_CA_BUNDLE_PATH=
OPENAI_MAX_RETRIES=4
OPENAI_RETRY_BASE_DELAY=1.5
EMBEDDING_WORKER_COUNT=4
EMBEDDING_BACKFILL_BATCH_SIZE=100
INGESTION_CHECKPOINT_INTERVAL=100
EMBEDDING_DIMENSIONS=512
EMBEDDING_BATCH_SIZE=32
CHUNK_SIZE=1800
CHUNK_OVERLAP=250

DEFAULT_ORG_ID=toi
DEFAULT_FEED_URL=https://embed-epaper.indiatimes.com/api/rss-feeds-json/toi/11_03_2026
DEFAULT_FEED_FILE=data/toi_11_03_2026.json
